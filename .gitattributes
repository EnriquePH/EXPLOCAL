# Texto versionado: normaliza a LF y evita diffs corruptos por CRLF/LF mixtos.
*.md    text eol=lf
*.qmd   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.R     text eol=lf
*.Rmd   text eol=lf
*.bib   text eol=lf
*.tex   text eol=lf
*.json  text eol=lf
*.cff   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf

# code/: se conserva byte a byte tal cual el original de 1996; nunca se
# debe tocar (ni normalizar EOL, ni intentar diff de texto).
code/** -text -diff

# Binarios: nunca como texto, sin normalización de fin de línea.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary
*.wmf   binary
*.wmz   binary
*.docx  binary
*.doc   binary
*.pdf   binary
*.rar   binary
*.zip   binary
*.exe   binary
*.obj   binary
*.res   binary
*.rws   binary
*.sym   binary
*.gid   binary
*.dsk   binary
*.hlp   binary
